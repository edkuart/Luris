# Neon Postgres: usa la cadena POOLED para DATABASE_URL (runtime) y la DIRECTA para DIRECT_URL (migraciones).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/luris?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/luris?sslmode=require"
AUTH_SECRET="replace-with-at-least-32-random-characters"
APP_URL="http://localhost:3000"
# AUTH_MODE=mock usa datos de ejemplo sin DB. Dejar vacio o "real" para autenticacion y persistencia reales.
AUTH_MODE="real"
DEMO_USER_EMAIL="demo@luris.gt"
DEMO_USER_PASSWORD="LurisDemo2026!"
STORAGE_PROVIDER="local"
STORAGE_BUCKET="luris-documents"
STORAGE_REGION=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
AI_PROVIDER="disabled"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
